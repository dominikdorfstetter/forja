---
import Base from "../../layouts/Base.astro";
import SeoHead from "../../components/SeoHead.astro";
import { fetchLegalDocBySlug, fetchSite, getSiteUrl } from "../../lib/api";
import { renderMarkdown } from "../../lib/markdown";
import { buildSeoMeta } from "../../lib/seo";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/");
}

let doc;
try {
  doc = await fetchLegalDocBySlug(slug);
} catch (e) {
  console.warn("[CMS] Failed to fetch legal document:", e instanceof Error ? e.message : e);
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const loc = doc.localizations[0];
const title = loc?.title ?? slug.replace(/-/g, " ");
const intro = renderMarkdown(loc?.intro);

const site = await fetchSite().catch(() => null);
const siteName = site?.name ?? "My Site";
const siteUrl = getSiteUrl();

const seo = buildSeoMeta({
  title: `${title} — ${siteName}`,
  description: `${title} for ${siteName}.`,
  canonicalUrl: `${siteUrl}/legal/${slug}/`,
  siteUrl,
  siteName,
});

Astro.response.headers.set("Cache-Control", "public, max-age=3600, s-maxage=86400");
---

<Base title={title}>
  <SeoHead seo={seo} slot="head" />
  <article class="max-w-prose mx-auto">
    <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-6">{title}</h1>
    {intro.length > 0 && <div class="prose" set:html={intro} />}
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-8">
      Last updated: {new Date(doc.updated_at).toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </p>
  </article>
</Base>
