---
import Base from "../../layouts/Base.astro";
import SeoHead from "../../components/SeoHead.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import { fetchBlogBySlug, fetchMedia, fetchSite, getSiteUrl } from "../../lib/api";
import type { MediaResponse } from "../../lib/api";
import { renderMarkdown } from "../../lib/markdown";
import { buildSeoMeta } from "../../lib/seo";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/blog");
}

let blog;
try {
  blog = await fetchBlogBySlug(slug);
} catch (e) {
  console.warn("[CMS] Failed to fetch blog by slug:", e instanceof Error ? e.message : e);
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const loc = blog.localizations[0];
const title = loc?.title ?? "Untitled";
const body = renderMarkdown(loc?.body);
const metaTitle = loc?.meta_title ?? title;
const metaDescription = loc?.meta_description ?? loc?.excerpt ?? "";

let coverMedia: MediaResponse | null = null;
if (blog.cover_image_id) {
  try {
    coverMedia = await fetchMedia(blog.cover_image_id);
  } catch (e) {
    console.warn("[CMS] Failed to fetch cover image:", e instanceof Error ? e.message : e);
  }
}

const date = new Date(blog.published_date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const site = await fetchSite().catch(() => null);
const siteName = site?.name ?? "My Site";
const siteUrl = getSiteUrl();

const seo = buildSeoMeta({
  title: metaTitle.includes(siteName) ? metaTitle : `${metaTitle} — ${siteName}`,
  description: metaDescription,
  canonicalUrl: `${siteUrl}/blog/${slug}/`,
  siteUrl,
  siteName,
  ogType: "article",
  ogImage: coverMedia?.public_url ?? undefined,
  ogImageAlt: title,
  article: {
    publishedTime: blog.published_date,
    author: blog.author,
    tags: blog.categories.map((c) => c.slug),
  },
});

Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=900");
---

<Base title={title} metaTitle={metaTitle} metaDescription={metaDescription}>
  <SeoHead seo={seo} slot="head" />
  <article class="blog-detail">
    <header class="blog-detail__header">
      <h1 class="blog-detail__title">{title}</h1>
      <div class="blog-detail__meta">
        <span>{date}</span>
        {blog.author && <span>{blog.author}</span>}
        {blog.reading_time_minutes && <span>{blog.reading_time_minutes} min read</span>}
      </div>
      {blog.categories.length > 0 && (
        <div class="blog-detail__categories">
          {blog.categories.map((cat) => (
            <a href={`/blog/category/${cat.slug}`} class="blog-detail__tag">{cat.slug}</a>
          ))}
        </div>
      )}
    </header>

    {coverMedia && (
      <ResponsiveImage
        media={coverMedia}
        alt={title}
        class="blog-detail__cover"
        sizes="(max-width: 768px) 100vw, 740px"
        loading="eager"
      />
    )}

    <div class="blog-detail__body" set:html={body} />
  </article>
</Base>
