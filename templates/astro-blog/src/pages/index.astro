---
import Base from "../layouts/Base.astro";
import BlogCard from "../components/BlogCard.astro";
import SeoHead from "../components/SeoHead.astro";
import { fetchSite, fetchFeaturedBlogs, fetchBlogDetails, fetchMediaBatch, getSiteUrl } from "../lib/api";
import type { BlogDetailResponse, MediaResponse, SiteInfo } from "../lib/api";
import { buildSeoMeta } from "../lib/seo";

let site: SiteInfo | null = null;
try {
  site = await fetchSite();
} catch (e) {
  console.warn("[CMS] Failed to fetch site info:", e instanceof Error ? e.message : e);
}

const siteName = site?.name ?? "My Site";
const siteDescription = site?.description ?? "A developer portfolio and blog.";
const siteUrl = getSiteUrl();

let featured: BlogDetailResponse[] = [];
try {
  const items = await fetchFeaturedBlogs(3);
  featured = await fetchBlogDetails(items.map((b) => b.id));
} catch (e) {
  console.warn("[CMS] Failed to fetch featured blogs:", e instanceof Error ? e.message : e);
}

// Batch-fetch cover images for featured posts
const coverIds = featured.map((b) => b.cover_image_id).filter(Boolean) as string[];
const mediaMap: Map<string, MediaResponse> = coverIds.length > 0
  ? await fetchMediaBatch(coverIds)
  : new Map();

const seo = buildSeoMeta({
  title: siteName,
  description: siteDescription,
  canonicalUrl: `${siteUrl}/`,
  siteUrl,
  siteName,
});

Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=600");
---

<Base title="Home" description={siteDescription}>
  <SeoHead seo={seo} slot="head" />

  {/* Hero */}
  <section class="pt-12 pb-10">
    <span class="inline-block text-xs font-semibold uppercase tracking-widest bg-gradient-to-r from-violet-600 to-violet-400 bg-clip-text text-transparent mb-3">
      Welcome
    </span>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-3">
      {siteName}
    </h1>
    <p class="text-base text-zinc-500 dark:text-zinc-400 max-w-lg leading-relaxed">
      {siteDescription}
    </p>
  </section>

  {/* Featured posts */}
  {featured.length > 0 && (
    <section>
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-semibold text-zinc-900 dark:text-zinc-100 uppercase tracking-wider">Featured</span>
        <div class="flex-1 h-px bg-zinc-200 dark:bg-zinc-800"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map((blog) => (
          <BlogCard
            blog={blog}
            coverMedia={blog.cover_image_id ? mediaMap.get(blog.cover_image_id) ?? null : null}
          />
        ))}
      </div>
      <p class="mt-8">
        <a href="/blog" class="text-sm font-medium text-violet-600 dark:text-violet-400 hover:text-violet-700 dark:hover:text-violet-300 no-underline hover:no-underline">
          View all posts &rarr;
        </a>
      </p>
    </section>
  )}
</Base>
