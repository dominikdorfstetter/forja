// Fallback generic link icon
const fallbackIcon =
  '<path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" stroke="currentColor" stroke-width="2" fill="none"/><path d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 10-5.656-5.656l-1.102 1.101" stroke="currentColor" stroke-width="2" fill="none"/>';

function getIcon(slug: string): string {
  const key = slug.toLowerCase().replace(/[^a-z]/g, "");
  return icons[key] ?? fallbackIcon;
}
---

<div class="flex gap-2" role="list" aria-label="Social links">
  {links.map((link) => (
    <a
      href={link.url}
      class="w-8 h-8 flex items-center justify-center rounded-lg border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400 hover:text-violet-600 dark:hover:text-violet-400 hover:border-violet-300 dark:hover:border-violet-700 no-underline hover:no-underline transition-colors duration-200"
      target="_blank"
      rel="noopener noreferrer"
      title={link.alt_text ?? link.title}
      role="listitem"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        width="16"
        height="16"
        fill="currentColor"
        aria-hidden="true"
        set:html={getIcon(link.icon)}
      />
      <span class="sr-only">{link.title}</span>
    </a>
  ))}
</div>
