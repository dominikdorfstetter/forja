---
import { fetchNavTree, type NavigationTree } from "../lib/api";
import SocialLinks from "./SocialLinks.astro";

interface Props {
  siteName: string;
}

const { siteName } = Astro.props;

let items: NavigationTree[] = [];
try {
  items = await fetchNavTree("footer");
} catch (e) {
  console.warn("[CMS] Failed to fetch footer nav:", e instanceof Error ? e.message : e);
}

function href(item: NavigationTree): string {
  if (item.external_url) return item.external_url;
  if (item.page_slug) return `/${item.page_slug}`;
  return "#";
}

const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12">
    {/* Brand */}
    <div>
      <a href="/" class="font-mono text-sm font-semibold text-zinc-900 dark:text-zinc-100 no-underline hover:text-violet-600 dark:hover:text-violet-400 hover:no-underline">
        {siteName}
      </a>
      <p class="text-xs text-zinc-500 dark:text-zinc-500 mt-1">Built with Forja</p>
    </div>

    {/* Nav links */}
    {items.length > 0 && (
      <nav aria-label="Footer navigation">
        <p class="text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-3">Links</p>
        <ul class="space-y-2">
          {items.map((item) => (
            <li>
              <a
                href={href(item)}
                target={item.open_in_new_tab ? "_blank" : undefined}
                rel={item.open_in_new_tab ? "noopener noreferrer" : undefined}
                class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-violet-600 dark:hover:text-violet-400 no-underline hover:no-underline transition-colors"
              >
                {item.title ?? "Untitled"}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    {/* Social */}
    <div>
      <p class="text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-3">Connect</p>
      <SocialLinks />
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4 border-t border-zinc-200 dark:border-zinc-800 text-center text-xs text-zinc-400 dark:text-zinc-500">
    <p>&copy; {year} {siteName}. All rights reserved.</p>
  </div>
</footer>
