---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

if (totalPages <= 1) return;

function pageUrl(page: number): string {
  if (page === 1) return `${baseUrl}/`;
  return `${baseUrl}/page/${page}/`;
}

// Build page number array with ellipsis
function pageNumbers(): (number | "...")[] {
  const pages: (number | "...")[] = [];
  if (totalPages <= 7) {
    for (let i = 1; i <= totalPages; i++) pages.push(i);
    return pages;
  }
  pages.push(1);
  if (currentPage > 3) pages.push("...");
  const start = Math.max(2, currentPage - 1);
  const end = Math.min(totalPages - 1, currentPage + 1);
  for (let i = start; i <= end; i++) pages.push(i);
  if (currentPage < totalPages - 2) pages.push("...");
  pages.push(totalPages);
  return pages;
}
---

<nav class="pagination" aria-label="Page navigation">
  {currentPage > 1 && (
    <a href={pageUrl(currentPage - 1)} class="pagination__link pagination__prev" aria-label="Previous page">&larr; Prev</a>
  )}

  <span class="pagination__pages">
    {pageNumbers().map((p) =>
      p === "..." ? (
        <span class="pagination__ellipsis">&hellip;</span>
      ) : p === currentPage ? (
        <span class="pagination__link pagination__current" aria-current="page">{p}</span>
      ) : (
        <a href={pageUrl(p)} class="pagination__link">{p}</a>
      )
    )}
  </span>

  {currentPage < totalPages && (
    <a href={pageUrl(currentPage + 1)} class="pagination__link pagination__next" aria-label="Next page">Next &rarr;</a>
  )}
</nav>
